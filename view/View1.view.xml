<mvc:View controllerName="ns.inventorymanagementui.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizdata="sap.viz.ui5.data"
    xmlns:vizfeed="sap.viz.ui5.controls.common.feeds"
    xmlns:popover="sap.viz.ui5.controls"
    displayBlock="true">

    <Page id="mainPage"
          title="Enterprise Inventory &amp; Stock Management"
          backgroundDesign="Solid"
          class="customPage">

        <!-- ── Header Bar ──────────────────────────────────────────── -->
        <customHeader>
            <Bar>
                <contentLeft>
                    <HBox alignItems="Center" class="sapUiSmallMarginBegin">
                        <core:Icon src="sap-icon://inventory" size="1.5rem" color="#ffffff" class="sapUiSmallMarginEnd"/>
                        <Title text="Inventory Management" level="H2" class="headerTitle"/>
                    </HBox>
                </contentLeft>
                <contentMiddle>
                    <Text text="SAP Fiori Dashboard" class="headerSubtitle"/>
                </contentMiddle>
                <contentRight>
                    <HBox alignItems="Center" class="sapUiSmallMarginEnd">
                        <Switch id="darkModeSwitch"
                                state="false"
                                change="onToggleDarkMode"
                                customTextOn="Dark"
                                customTextOff="Light"
                                class="sapUiSmallMarginEnd"/>
                        <Button icon="sap-icon://refresh"
                                text="Refresh"
                                type="Transparent"
                                press="onRefresh"
                                class="headerBtn"/>
                        <Button icon="sap-icon://download"
                                text="Export"
                                type="Transparent"
                                press="onExportCSV"
                                class="headerBtn"/>
                    </HBox>
                </contentRight>
            </Bar>
        </customHeader>

        <content>

            <!-- ── KPI Summary Cards ────────────────────────────────── -->
            <HBox id="kpiRow" wrap="Wrap" class="kpiRow sapUiMediumMarginTop sapUiMediumMarginBeginEnd">

                <GenericTile id="tileTotalProducts"
                             header="Total Products"
                             subheader="In Catalogue"
                             class="kpiTile sapUiTinyMarginEnd sapUiTinyMarginBottom"
                             press="onTilePress">
                    <TileContent>
                        <NumericContent value="{/totalItems}"
                                        icon="sap-icon://product"
                                        valueColor="Good"
                                        scale=""/>
                    </TileContent>
                </GenericTile>

                <GenericTile id="tileLowStock"
                             header="Low Stock Alert"
                             subheader="Items below 10 units"
                             class="kpiTile sapUiTinyMarginEnd sapUiTinyMarginBottom"
                             press="onTilePress">
                    <TileContent>
                        <NumericContent value="{/lowStockCount}"
                                        icon="sap-icon://alert"
                                        valueColor="Critical"
                                        scale=""/>
                    </TileContent>
                </GenericTile>

                <GenericTile id="tileOutOfStock"
                             header="Out of Stock"
                             subheader="Needs replenishment"
                             class="kpiTile sapUiTinyMarginEnd sapUiTinyMarginBottom"
                             press="onTilePress">
                    <TileContent>
                        <NumericContent value="{/outOfStockCount}"
                                        icon="sap-icon://cancel"
                                        valueColor="Error"
                                        scale=""/>
                    </TileContent>
                </GenericTile>

                <GenericTile id="tileTotalValue"
                             header="Total Stock Value"
                             subheader="All categories"
                             class="kpiTile sapUiTinyMarginBottom"
                             press="onTilePress">
                    <TileContent>
                        <NumericContent value="{/totalValueDisplay}"
                                        icon="sap-icon://money-bills"
                                        valueColor="Good"
                                        scale="{/totalValueScale}"/>
                    </TileContent>
                </GenericTile>

            </HBox>

            <!-- ── Charts Row ────────────────────────────────────────── -->
            <HBox wrap="Wrap"
                  class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop chartsRow">

                <!-- Pie Chart -->
                <Panel id="piePanel"
                       headerText="Stock by Category"
                       class="chartPanel sapUiTinyMarginEnd sapUiSmallMarginBottom"
                       expandable="false">
                    <viz:VizFrame id="pieChart"
                                  vizType="pie"
                                  width="100%"
                                  height="300px"
                                  uiConfig="{applicationSet:'fiori'}">
                        <viz:dataset>
                            <vizdata:FlattenedDataset data="{/categoryData}">
                                <vizdata:dimensions>
                                    <vizdata:DimensionDefinition name="Category" value="{Category}"/>
                                </vizdata:dimensions>
                                <vizdata:measures>
                                    <vizdata:MeasureDefinition name="Stock" value="{Stock}"/>
                                </vizdata:measures>
                            </vizdata:FlattenedDataset>
                        </viz:dataset>
                        <viz:feeds>
                            <vizfeed:FeedItem uid="size"  type="Measure"    values="Stock"/>
                            <vizfeed:FeedItem uid="color" type="Dimension"  values="Category"/>
                        </viz:feeds>
                    </viz:VizFrame>
                </Panel>

                <!-- Bar Chart -->
                <Panel id="barPanel"
                       headerText="Top Products by Stock Level"
                       class="chartPanel sapUiSmallMarginBottom"
                       expandable="false">
                    <viz:VizFrame id="barChart"
                                  vizType="column"
                                  width="100%"
                                  height="300px"
                                  uiConfig="{applicationSet:'fiori'}">
                        <viz:dataset>
                            <vizdata:FlattenedDataset data="{/products}">
                                <vizdata:dimensions>
                                    <vizdata:DimensionDefinition name="Product" value="{ProductName}"/>
                                </vizdata:dimensions>
                                <vizdata:measures>
                                    <vizdata:MeasureDefinition name="Stock" value="{Stock}"/>
                                </vizdata:measures>
                            </vizdata:FlattenedDataset>
                        </viz:dataset>
                        <viz:feeds>
                            <vizfeed:FeedItem uid="categoryAxis" type="Dimension" values="Product"/>
                            <vizfeed:FeedItem uid="valueAxis"    type="Measure"   values="Stock"/>
                        </viz:feeds>
                    </viz:VizFrame>
                </Panel>

            </HBox>

            <!-- ── Table Toolbar ─────────────────────────────────────── -->
            <VBox class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop">

                <Toolbar class="tableToolbar">
                    <core:Icon src="sap-icon://table-view" size="1rem" class="sapUiSmallMarginEnd"/>
                    <Title text="Product Inventory" level="H3"/>
                    <ToolbarSpacer/>
                    <SearchField id="searchField"
                                 placeholder="Search by name or category..."
                                 liveChange="onSearch"
                                 width="280px"
                                 class="sapUiSmallMarginEnd"/>
                    <Select id="categoryFilter"
                            change="onCategoryFilter"
                            class="sapUiSmallMarginEnd">
                        <core:Item key="" text="All Categories"/>
                        <core:Item key="Electronics"    text="Electronics"/>
                        <core:Item key="Furniture"      text="Furniture"/>
                        <core:Item key="Storage"        text="Storage"/>
                        <core:Item key="Office Supplies" text="Office Supplies"/>
                        <core:Item key="Accessories"    text="Accessories"/>
                    </Select>
                    <Button id="btnAdd"
                            text="Add Product"
                            type="Emphasized"
                            icon="sap-icon://add"
                            press="onOpenAddDialog"/>
                </Toolbar>

                <!-- ── Products Table ─────────────────────────────────── -->
                <Table id="inventoryTable"
                       items="{/products}"
                       growing="true"
                       growingThreshold="15"
                       growingScrollToLoad="true"
                       alternateRowColors="true"
                       class="inventoryTable"
                       noDataText="No products found. Click 'Add Product' to get started.">

                    <headerToolbar>
                        <Toolbar>
                            <Text text="Showing {/totalItems} products"/>
                            <ToolbarSpacer/>
                            <Button icon="sap-icon://sort"    text="Sort"   type="Transparent" press="onSortDialog"/>
                            <Button icon="sap-icon://filter"  text="Filter" type="Transparent" press="onFilterDialog"/>
                        </Toolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="100px">
                            <Text text="Product ID"/>
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Product Name"/>
                        </Column>
                        <Column width="130px" minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Category"/>
                        </Column>
                        <Column width="120px" hAlign="End">
                            <Text text="Stock"/>
                        </Column>
                        <Column width="120px" hAlign="End" minScreenWidth="Desktop" demandPopin="true">
                            <Text text="Price (₹)"/>
                        </Column>
                        <Column width="140px" minScreenWidth="Desktop" demandPopin="true">
                            <Text text="Last Updated"/>
                        </Column>
                        <Column width="130px" hAlign="Center">
                            <Text text="Status"/>
                        </Column>
                        <Column width="120px" hAlign="Center">
                            <Text text="Actions"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem type="Navigation" press="onItemPress">
                            <cells>
                                <ObjectIdentifier title="{ProductID}" class="productIdCell"/>
                                <ObjectIdentifier title="{ProductName}" class="productNameCell"/>
                                <Label text="{Category}" class="categoryLabel"/>
                                <ObjectStatus
                                    text="{Stock} units"
                                    state="{= ${Stock} === 0 ? 'Error' : ${Stock} &lt; 10 ? 'Error' : ${Stock} &lt; 30 ? 'Warning' : 'Success'}"
                                    icon="{= ${Stock} === 0 ? 'sap-icon://cancel' : ${Stock} &lt; 10 ? 'sap-icon://alert' : 'sap-icon://sys-enter-2'}"/>
                                <ObjectNumber
                                    number="{path: 'Price', formatter: '.formatNumber'}"
                                    unit="₹"
                                    state="None"/>
                                <Text text="{LastUpdated}"/>
                                <ObjectStatus
                                    text="{= ${Stock} === 0 ? 'Out of Stock' : ${Stock} &lt; 10 ? 'Low Stock' : ${Stock} &lt; 30 ? 'Limited' : 'In Stock'}"
                                    state="{= ${Stock} === 0 ? 'Error' : ${Stock} &lt; 10 ? 'Error' : ${Stock} &lt; 30 ? 'Warning' : 'Success'}"/>
                                <HBox justifyContent="Center">
                                    <Button icon="sap-icon://edit"
                                            type="Transparent"
                                            tooltip="Edit Product"
                                            press="onEditItem"
                                            class="actionBtn"/>
                                    <Button icon="sap-icon://delete"
                                            type="Transparent"
                                            tooltip="Delete Product"
                                            press="onDeleteItem"
                                            class="actionBtn deleteBtn"/>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

            </VBox>

        </content>

        <!-- ── Footer ────────────────────────────────────────────────── -->
        <footer>
            <Toolbar class="footerBar">
                <core:Icon src="sap-icon://sap-logo-shape" size="1rem" class="sapUiSmallMarginEnd"/>
                <Text text="SAP Fiori Inventory Management v1.0"/>
                <ToolbarSpacer/>
                <Text id="lastSyncText" text="Last sync: Never"/>
                <Button text="Save All Changes"
                        type="Emphasized"
                        icon="sap-icon://save"
                        press="onSaveAll"
                        class="sapUiSmallMarginBegin"/>
            </Toolbar>
        </footer>

    </Page>
</mvc:View>